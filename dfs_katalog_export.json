<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="theme-color" content="#eef3fa">
<title>UAV & Drohnen Katalog – HS RheinMain</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#eef3fa;--s1:#ffffff;--s2:#f3f7fc;--s3:#e7eef8;
  --b0:rgba(15,23,42,.07);--b1:rgba(15,23,42,.13);--b2:rgba(15,23,42,.22);
  --tx:#1f2a3d;--mu:#5b6b82;--fa:#9aa7bd;
  --ac:#2563eb;--mc:#0891b2;--fw:#059669;--vt:#7c3aed;
  --r:12px;--rs:8px;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--tx);font-family:'Inter',sans-serif;min-height:100vh}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(15,23,42,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(15,23,42,.035) 1px,transparent 1px);background-size:46px 46px;pointer-events:none;z-index:0}
body::after{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 90% 45% at 50% -5%,rgba(59,130,246,.045) 0%,transparent 65%);pointer-events:none;z-index:0}
.sky{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
.sky-drone{position:absolute;font-size:22px;opacity:0;animation:droneFly linear infinite}
.d1{top:12%;left:-80px;animation-duration:22s}.d2{top:28%;left:-80px;animation-duration:31s;animation-delay:-10s;font-size:16px}.d3{top:18%;left:-80px;animation-duration:18s;animation-delay:-6s;font-size:28px}.d4{top:8%;left:-80px;animation-duration:38s;animation-delay:-20s;font-size:13px}
@keyframes droneFly{0%{transform:translate(-10vw,0);opacity:0}5%{opacity:.16}95%{opacity:.16}100%{transform:translate(115vw,-8vh) scale(.7);opacity:0}}
@media(prefers-reduced-motion:reduce){.sky-drone{animation:none;opacity:0}}
.avx-topnav{position:fixed;top:0;left:0;right:0;z-index:300;min-height:48px;display:flex;align-items:center;gap:14px;background:#0f172a;border-bottom:1px solid #334155;padding:7px 16px;font-family:'Inter',system-ui,sans-serif;overflow-x:auto;white-space:nowrap}
.avx-topnav a{text-decoration:none}
.avx-brand{color:#fff;font-weight:800;font-size:.9rem;flex:0 0 auto}
.avx-links{display:flex;gap:8px;flex:0 0 auto;margin-left:auto}
.avx-pill{color:#cbd5e1;font-size:.85rem;font-weight:600;padding:6px 14px;border-radius:999px;border:1px solid #334155;transition:background .15s,color .15s,border-color .15s}
.avx-pill:hover{color:#fff;border-color:#4fc3f7}
.avx-pill.avx-active{background:#2563eb;border-color:#2563eb;color:#fff}
.tb{position:fixed;top:48px;left:0;right:0;z-index:200;height:54px;background:rgba(255,255,255,.9);backdrop-filter:blur(18px);border-bottom:1px solid var(--b1);display:flex;align-items:center;padding:0 clamp(1rem,4vw,2.5rem);gap:10px}
.tb-logo{display:flex;align-items:center;gap:9px;font-size:13px;font-weight:600;color:var(--tx);cursor:pointer;background:none;border:none;font-family:inherit}
.tb-logo svg{width:20px;height:20px;fill:none;stroke:#2563eb;stroke-width:2;flex-shrink:0}
.tb-div{width:1px;height:16px;background:var(--b1)}
.tb-cr{font-size:12px;color:var(--mu);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:300px}
.tb-cr b{color:var(--tx);font-weight:500}
.tb-badge{margin-left:auto;font-size:11px;padding:3px 11px;border-radius:20px;background:rgba(59,130,246,.09);border:1px solid rgba(59,130,246,.18);color:#1d4ed8;white-space:nowrap}
.view{position:relative;z-index:1;padding-top:102px}
.hide{display:none!important}
/* STARTSEITE */
.hh{text-align:center;padding:4.5rem clamp(1rem,4vw,2.5rem) 2.5rem;max-width:820px;margin:0 auto}
.ey{display:inline-flex;align-items:center;gap:6px;font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#2563eb;margin-bottom:1.4rem;padding:5px 14px;border-radius:20px;background:rgba(59,130,246,.08);border:1px solid rgba(59,130,246,.14)}
.ey svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:2}
.hh h1{font-size:clamp(1.9rem,4.5vw,2.9rem);font-weight:700;line-height:1.1;letter-spacing:-.03em;color:#0f172a;margin-bottom:.9rem}
.hh h1 em{font-style:normal;color:#2563eb}
.hh p{font-size:14.5px;color:var(--mu);line-height:1.7;max-width:500px;margin:0 auto 2.2rem}
.hs{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--b1);border-radius:var(--r);overflow:hidden;border:1px solid var(--b1);max-width:380px;margin:0 auto 3.5rem}
.hsc{background:var(--s1);padding:1.1rem .8rem;text-align:center}
.hsc-n{font-size:24px;font-weight:700;font-family:'Space Mono',monospace;color:#0f172a}
.hsc-l{font-size:10px;color:var(--mu);margin-top:2px}
.cg{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;padding:0 clamp(1rem,4vw,2.5rem) 5rem;max-width:min(1000px,94vw);margin:0 auto}
.cc{background:var(--s1);border:1px solid var(--b0);border-radius:16px;cursor:pointer;text-align:left;overflow:hidden;display:flex;flex-direction:column;padding:0;transition:transform .2s,box-shadow .2s}
.cc:hover{transform:translateY(-5px);box-shadow:0 18px 44px rgba(15,23,42,.13)}
.cc-banner{height:130px;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.cc-banner::before{content:'';position:absolute;inset:0;opacity:.55;background-image:radial-gradient(circle at 1px 1px,rgba(15,23,42,.09) 1px,transparent 0);background-size:15px 15px}
.cc-banner .drone-icon{font-size:54px;position:relative;z-index:1}
.cc-info{padding:1.2rem 1.35rem 1.4rem;display:flex;flex-direction:column;gap:7px;flex:1}
.cc-info h3{font-size:19px;font-weight:700;color:#0f172a}
.cc-sub{font-size:12.5px;color:var(--mu);line-height:1.55;flex:1}
.cc-go{display:inline-flex;align-items:center;gap:6px;font-size:13px;font-weight:600;margin-top:6px}
.cc-go svg{width:15px;height:15px;fill:none;stroke-width:2;transition:transform .18s}
.cc:hover .cc-go svg{transform:translateX(4px)}
.cc.mc .cc-banner{background:linear-gradient(135deg,rgba(8,145,178,.16),rgba(8,145,178,.03))}
.cc.fw .cc-banner{background:linear-gradient(135deg,rgba(5,150,105,.16),rgba(5,150,105,.03))}
.cc.vt .cc-banner{background:linear-gradient(135deg,rgba(124,58,237,.16),rgba(124,58,237,.03))}
/* DETAIL */
.dh{border-bottom:1px solid var(--b0);padding:1.8rem clamp(1rem,4vw,2.5rem);max-width:min(1440px,94vw);margin:0 auto}
.bk{display:inline-flex;align-items:center;gap:5px;font-size:12.5px;color:var(--mu);background:none;border:none;cursor:pointer;font-family:inherit;padding:0;margin-bottom:.7rem;transition:color .15s}
.bk:hover{color:var(--tx)}.bk svg{width:14px;height:14px;stroke:currentColor;fill:none}
.dh h2{font-size:clamp(1.4rem,3vw,1.9rem);font-weight:700;letter-spacing:-.02em;color:#0f172a;margin-bottom:.35rem}
.dh p{font-size:13.5px;color:var(--mu);max-width:580px;line-height:1.6}
.dh-stats{display:flex;flex-wrap:wrap;gap:8px;margin-top:1.2rem}
.ds{padding:8px 16px;background:var(--s1);border:1px solid var(--b0);border-radius:var(--rs);display:flex;flex-direction:column;align-items:center;min-width:80px}
.ds-n{font-size:19px;font-weight:700;font-family:'Space Mono',monospace}
.ds-l{font-size:10px;color:var(--mu);margin-top:1px}
/* TOOLBAR */
.dtb{position:sticky;top:102px;z-index:100;background:rgba(255,255,255,.93);backdrop-filter:blur(14px);border-bottom:1px solid var(--b0);padding:.7rem clamp(1rem,4vw,2.5rem)}
.dtb-in{max-width:min(1440px,94vw);margin:0 auto;display:flex;flex-wrap:wrap;gap:8px;align-items:center}
.sw{position:relative;flex:1;min-width:150px;max-width:250px}
.sw svg{position:absolute;left:9px;top:50%;transform:translateY(-50%);width:13px;height:13px;stroke:var(--fa);fill:none}
.si{width:100%;padding:7px 9px 7px 30px;background:var(--s2);border:1px solid var(--b1);border-radius:var(--rs);color:var(--tx);font-family:inherit;font-size:12.5px;outline:none;transition:border-color .15s}
.si:focus{border-color:var(--b2)}.si::placeholder{color:var(--fa)}
.sl{padding:7px 10px;background:var(--s2);border:1px solid var(--b1);border-radius:var(--rs);color:var(--tx);font-family:inherit;font-size:12px;outline:none;cursor:pointer}
.price-filter{display:flex;align-items:center;gap:7px;flex-shrink:0}
.price-filter label{font-size:11.5px;color:var(--mu);white-space:nowrap}
.price-filter input[type=range]{width:85px;accent-color:var(--ac);cursor:pointer}
.price-val{font-size:11px;font-weight:700;font-family:'Space Mono',monospace;color:var(--tx);white-space:nowrap;min-width:58px}
.ri{margin-left:auto;font-size:11.5px;color:var(--mu);white-space:nowrap}.ri b{color:var(--tx)}
/* EU-LEGENDE */
.eu-legende{background:var(--s1);border:1px solid var(--b0);border-radius:8px;padding:.85rem 1rem;margin:0 clamp(1rem,4vw,2.5rem);max-width:min(1440px,94vw);display:flex;flex-wrap:wrap;gap:6px 14px;align-items:center}
.eu-legende-title{font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--fa);flex-basis:100%;margin-bottom:2px}
.eu-legende-item{display:inline-flex;align-items:center;gap:5px;font-size:11px;color:var(--mu)}
/* KARTEN */
.drone-grid{display:flex;flex-direction:column;gap:10px;max-width:min(1440px,94vw);margin:0 auto;padding:1.2rem clamp(1rem,4vw,2.5rem) 5rem}
.dc{background:var(--s1);border:1px solid var(--b0);border-radius:var(--r);overflow:hidden;transition:border-color .15s,box-shadow .15s}
.dc:hover{border-color:var(--b1);box-shadow:0 4px 18px rgba(15,23,42,.08)}
.dc-top{display:grid;grid-template-columns:110px 1fr auto;align-items:stretch}
/* Bild-Thumbnail */
.dc-thumb{width:110px;min-height:90px;background:var(--s2);flex-shrink:0;border-right:1px solid var(--b0);position:relative;overflow:hidden;cursor:zoom-in}
.dc-thumb img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s;position:absolute;inset:0}
.dc-thumb:hover img{transform:scale(1.07)}
.dc-thumb::after{content:'\1F50D';position:absolute;bottom:5px;right:5px;font-size:12px;opacity:0;transition:opacity .2s;pointer-events:none}
.dc-thumb:hover::after{opacity:.8}
.dc-ph{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;position:absolute;inset:0;background:linear-gradient(90deg,var(--s2) 25%,var(--s3) 50%,var(--s2) 75%);background-size:200% 100%;animation:shimmer 1.8s infinite}
.dc-ph-icon{font-size:26px;opacity:.5}
.dc-ph-txt{font-size:8.5px;color:var(--fa);text-transform:uppercase;letter-spacing:.06em}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
.dc-img-bdg{position:absolute;top:5px;left:5px;display:flex;flex-direction:column;gap:3px;z-index:2}
.dc-img-b{font-size:8.5px;font-weight:700;letter-spacing:.04em;text-transform:uppercase;padding:2px 6px;border-radius:3px;backdrop-filter:blur(8px)}
.dc-img-b-bf{background:rgba(255,255,255,.88);color:var(--tx);border:1px solid rgba(15,23,42,.12)}
.dc-img-b-yr{background:rgba(59,130,246,.25);color:#1d4ed8;border:1px solid rgba(59,130,246,.3)}
.dc-meta{padding:.8rem 1rem;display:flex;flex-direction:column;justify-content:center;gap:3px;min-width:0}
.dc-name{font-size:15px;font-weight:700;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:2px}
.dc-hersteller{font-size:11.5px;color:var(--mu)}
.dc-price{font-size:13px;font-weight:700;font-family:'Space Mono',monospace;color:var(--ac);margin-top:2px}
.dc-price.classified{font-family:'Inter',sans-serif;color:var(--fa);font-size:11px;font-weight:400}
.dc-quickstats{display:flex;border-top:1px solid var(--b0);background:var(--s2)}
.dc-qs-item{flex:1;padding:.45rem .6rem;text-align:center;border-right:1px solid var(--b0)}
.dc-qs-item:last-child{border-right:none}
.dc-qs-val{font-size:12px;font-weight:700;font-family:'Space Mono',monospace;color:#0f172a;line-height:1.2}
.dc-qs-lbl{font-size:9.5px;text-transform:uppercase;letter-spacing:.07em;color:var(--fa);font-weight:700;margin-top:1px}
.dc-badges{display:flex;flex-direction:column;align-items:flex-end;gap:5px;padding:.6rem .9rem;flex-shrink:0;justify-content:center}
.bdg-bauform{display:inline-flex;align-items:center;padding:3px 9px;border-radius:4px;font-size:10.5px;font-weight:700;white-space:nowrap}
.bdg-mc{background:rgba(8,145,178,.1);color:#0891b2;border:1px solid rgba(8,145,178,.22)}
.bdg-fw{background:rgba(5,150,105,.1);color:#059669;border:1px solid rgba(5,150,105,.22)}
.bdg-vt{background:rgba(124,58,237,.1);color:#7c3aed;border:1px solid rgba(124,58,237,.22)}
.bdg-eu{display:inline-flex;align-items:center;padding:2px 8px;border-radius:4px;font-size:10px;font-weight:700;white-space:nowrap;margin-top:2px}
.eu-c0{background:rgba(22,163,74,.12);color:#16a34a;border:1px solid rgba(22,163,74,.25)}
.eu-c1{background:rgba(37,99,235,.1);color:#1d4ed8;border:1px solid rgba(37,99,235,.22)}
.eu-c2{background:rgba(217,119,6,.12);color:#b45309;border:1px solid rgba(217,119,6,.25)}
.eu-c3{background:rgba(220,38,38,.1);color:#b91c1c;border:1px solid rgba(220,38,38,.22)}
.eu-spc{background:rgba(124,58,237,.1);color:#7c3aed;border:1px solid rgba(124,58,237,.22)}
.dc-toggle{width:100%;background:none;border:none;border-top:1px solid var(--b0);padding:.55rem 1rem;color:var(--mu);font-family:inherit;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;transition:background .15s}
.dc-toggle:hover{background:rgba(0,0,0,.02)}
.dc-toggle svg{width:12px;height:12px;stroke:currentColor;fill:none;transition:transform .2s}
.dc-toggle.open svg{transform:rotate(180deg)}
.dc-body{display:none;padding:1rem 1.1rem;border-top:1px solid var(--b0);background:var(--bg)}
.dc-body.open{display:block}
.dc-desc{font-size:13px;color:var(--tx);line-height:1.65;padding:.8rem 1rem;background:var(--s1);border-radius:6px;border-left:2px solid var(--b2);margin-bottom:.9rem}
.dc-eu-box{background:var(--s1);border:1px solid var(--b0);border-radius:6px;padding:.75rem 1rem;margin-bottom:.9rem;display:flex;flex-wrap:wrap;gap:10px;align-items:flex-start}
.dc-eu-box-title{font-size:9.5px;text-transform:uppercase;letter-spacing:.08em;color:var(--fa);font-weight:700;width:100%;margin-bottom:2px}
.dc-eu-col{display:flex;flex-direction:column;gap:4px;min-width:110px;flex:1}
.dc-eu-label{font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:var(--fa);font-weight:700}
.dc-eu-val{font-size:12px;color:var(--tx);font-weight:500;line-height:1.35}
.dc-eu-note{font-size:10.5px;color:var(--mu);font-style:italic;width:100%;margin-top:2px}
.fs-chip{display:inline-block;padding:2px 7px;border-radius:4px;font-size:10px;font-weight:700}
.fs-yes{background:rgba(220,38,38,.1);color:#b91c1c;border:1px solid rgba(220,38,38,.2)}
.fs-no{background:rgba(22,163,74,.1);color:#15803d;border:1px solid rgba(22,163,74,.2)}
.fs-a1{background:rgba(22,163,74,.1);color:#15803d;border:1px solid rgba(22,163,74,.2)}
.fs-a2{background:rgba(217,119,6,.1);color:#b45309;border:1px solid rgba(217,119,6,.2)}
.fs-a3{background:rgba(220,38,38,.1);color:#b91c1c;border:1px solid rgba(220,38,38,.2)}
.fs-spc{background:rgba(124,58,237,.1);color:#7c3aed;border:1px solid rgba(124,58,237,.2)}
.fs-mil{background:rgba(15,23,42,.08);color:var(--tx);border:1px solid var(--b1)}
.dc-datengrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1px;background:var(--b0);border-radius:6px;overflow:hidden;border:1px solid var(--b0);margin-bottom:.9rem}
.dc-daten-cell{background:var(--s1);padding:.6rem .8rem}
.dc-daten-label{font-size:9.5px;text-transform:uppercase;letter-spacing:.08em;color:var(--fa);font-weight:700;margin-bottom:2px}
.dc-daten-val{font-size:12px;color:var(--tx);font-weight:500;line-height:1.3}
.dc-daten-cell.price-cell .dc-daten-val{font-family:'Space Mono',monospace;color:var(--ac);font-weight:700;font-size:13px}
.dc-daten-cell.price-cell .dc-daten-val.classified{font-family:'Inter',sans-serif;color:var(--mu);font-size:12px;font-weight:400}
.dc-links{display:flex;gap:8px;flex-wrap:wrap;margin-top:.3rem}
.dc-link-btn{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;font-weight:600;padding:6px 13px;border-radius:6px;cursor:pointer;border:1px solid;text-decoration:none;transition:all .15s;font-family:inherit}
.dc-link-ext{background:rgba(37,99,235,.09);border-color:rgba(37,99,235,.22);color:#2563eb}
.dc-link-ext:hover{background:#2563eb;color:#fff;border-color:#2563eb}
.no-results{text-align:center;padding:3rem 1rem;color:var(--mu);font-size:14px}
.no-results svg{width:40px;height:40px;stroke:var(--fa);fill:none;margin:0 auto .8rem;display:block}
@media(max-width:600px){.dc-top{grid-template-columns:64px 1fr}.dc-badges{display:none}.price-filter label{display:none}}
@media(max-width:760px){.tb .tb-badge{display:none}.price-filter input[type=range]{width:65px}}
</style>
</head>
