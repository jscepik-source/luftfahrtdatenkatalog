<!-- STARTSEITE -->
<div class="view" id="vHome">
  <div class="hh">
    <div class="ey"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>Studentisches Projekt · Fachbereich Ingenieurwissenschaften</div>
    <h1>UAV & <em>Drohnen</em> Katalog</h1>
    <p>100+ kommerzielle, industrielle und militärische Drohnen — mit EU-Regulierung, Führerscheinpflicht und Preisen. Wähle eine Bauform.</p>
    <div class="hs">
      <div class="hsc"><div class="hsc-n" id="statTotal">0</div><div class="hsc-l">Drohnen</div></div>
      <div class="hsc"><div class="hsc-n">3</div><div class="hsc-l">Bauformen</div></div>
      <div class="hsc"><div class="hsc-n" id="statH">0</div><div class="hsc-l">Hersteller</div></div>
    </div>
  </div>
  <div class="cg">
    <button class="cc mc" onclick="loadBauform('Multicopter')">
