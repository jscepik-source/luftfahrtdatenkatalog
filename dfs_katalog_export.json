function loadDroneImg(name, el) {
  const url = DRONE_IMGS[name];
  if (!url) return; // kein Bild → Emoji-Platzhalter bleibt
  const ph = el.querySelector('.dc-ph');
  const img = document.createElement('img');
  img.alt = name;
  img.loading = 'lazy';
  img.onload = function() { if (ph) ph.style.display = 'none'; };
  img.onerror = function() { img.remove(); }; // bei 404 → Platzhalter bleibt
  el.appendChild(img);
  img.src = url;
}

const imgObserver = new IntersectionObserver((entries, obs) => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    loadDroneImg(e.target.dataset.drone, e.target);
    obs.unobserve(e.target);
  });
}, { rootMargin: '300px' });

function observeThumb(el) { imgObserver.observe(el); }

function badgeClass(bf){return bf==='Multicopter'?'bdg-mc':bf==='VTOL'?'bdg-vt':'bdg-fw';}
function bauformIcon(bf){return bf==='Multicopter'?'🚁':bf==='VTOL'?'🛸':'✈️';}
function euBadgeClass(eu){const m={'C0':'eu-c0','C1':'eu-c1','C2':'eu-c2','C3':'eu-c3','Specific':'eu-spc','Militär':'eu-spc','—':'eu-spc'};return m[eu]||'eu-spc';}
function fscheinChip(fs){
  if(fs==='Nein') return `<span class="fs-chip fs-no">✓ Kein Führerschein</span>`;
  if(fs.includes('A1/A3')) return `<span class="fs-chip fs-a1">A1/A3-Nachweis</span>`;
  if(fs.includes('A2')) return `<span class="fs-chip fs-a2">A2-Fernpilotenzeugnis</span>`;
  if(fs==='Militär') return `<span class="fs-chip fs-mil">Militär</span>`;
  return `<span class="fs-chip fs-spc">Spez. Genehmigung</span>`;
}
function katChip(kat){
  if(kat.includes('A1')) return `<span class="fs-chip fs-a1">${esc(kat)}</span>`;
  if(kat.includes('A2')) return `<span class="fs-chip fs-a2">${esc(kat)}</span>`;
  if(kat.includes('A3')) return `<span class="fs-chip fs-a3">${esc(kat)}</span>`;
  if(kat.includes('Militär')) return `<span class="fs-chip fs-mil">${esc(kat)}</span>`;
  return `<span class="fs-chip fs-spc">${esc(kat)}</span>`;
}
function euNote(d){
  if(d.eu==='Militär') return 'Rein militärische Nutzung — EU-Drohnenverordnung nicht anwendbar. Nationale Verteidigungsregelungen gelten.';
  if(d.eu==='C0') return 'Kein EU-Führerschein erforderlich. Keine Registrierungspflicht in den meisten Ländern (Freizeitnutzung). Pflichtversicherung und 120m-Höhenlimit beachten.';
  if(d.eu==='C1') return 'EU-Kompetenznachweis A1/A3 erforderlich (Online-Kurs + Prüfung, ~30 Min.). Registrierung als Betreiber beim LBA. Open A1: nahe an Einzelpersonen, keine Menschenmengen überfliegen.';
  if(d.eu==='C2') return 'A2-Fernpilotenzeugnis (Theorie + Praxis + Selbsterklärung) für Open A2 nötig: min. 30 m zu Personen (5 m im Langsamflug). Ohne A2-Zeugnis nur Open A3 (150 m von Gebäuden/Personen).';
  if(d.eu==='C3') return 'A1/A3-Nachweis reicht, da nur Open A3 erlaubt. Mindestabstand 150 m zu Wohn-/Gewerbe-/Erholungsgebieten und Personen. Keine unbeteiligten Personen im Flugbereich.';
  return 'Betrieb in der Specific-Kategorie: Individuelle Betriebsgenehmigung oder STS (Standard-Szenario) nötig. Gilt für MTOW >25 kg, BVLOS-Flüge oder nicht-klassifizierte Systeme.';
}
function buildCard(d,i){
  const idx=`c${i}`;
  const isCl=(d.preis===0);
  const preisStr=isCl?'Auf Anfrage / Militär':`ab ${d.preis.toLocaleString('de')} €`;
  return `<div class="dc">
  <div class="dc-top">
    <div class="dc-thumb" data-drone="${d.n.replace(/"/g,'&quot;')}" id="thumb_${i}">
      <div class="dc-ph">
        <span class="dc-ph-icon">${bauformIcon(d.bf)}</span>
        <span class="dc-ph-txt">Lade Bild…</span>
      </div>
      <div class="dc-img-bdg">
        <span class="dc-img-b dc-img-b-bf">${d.bf}</span>
        <span class="dc-img-b dc-img-b-yr">${d.bj}</span>
      </div>
    </div>
    <div class="dc-meta">
      <div class="dc-name">${esc(d.n)}</div>
      <div class="dc-hersteller">${esc(d.h)}</div>
      ${isCl?`<span class="dc-price classified">Auf Anfrage / Militär</span>`:`<span class="dc-price">ab ${d.preis.toLocaleString('de')} €</span>`}
    </div>
    <div class="dc-badges">
      <span class="bdg-bauform ${badgeClass(d.bf)}">${esc(d.bf)}</span>
      ${d.eu!=='—'?`<span class="bdg-eu ${euBadgeClass(d.eu)}">${esc(d.eu)}</span>`:''}
    </div>
  </div>
  <div class="dc-quickstats">
    <div class="dc-qs-item"><div class="dc-qs-val">${esc(d.gw)||'—'}</div><div class="dc-qs-lbl">Gewicht (leer)</div></div>
    <div class="dc-qs-item"><div class="dc-qs-val">${esc(d.fd)||'—'}</div><div class="dc-qs-lbl">Flugdauer</div></div>
    <div class="dc-qs-item"><div class="dc-qs-val">${esc(d.rw)||'—'}</div><div class="dc-qs-lbl">Reichweite</div></div>
  </div>
  <button class="dc-toggle" data-id="${idx}" onclick="toggleCard(this)" aria-expanded="false">Mehr Details <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></button>
  <div class="dc-body" data-id="${idx}">
    ${d.di?`<div class="dc-desc">${esc(d.di)}</div>`:''}
    <div class="dc-eu-box">
      <div class="dc-eu-box-title">🇪🇺 EU-Regulierung (EASA)</div>
      <div class="dc-eu-col"><div class="dc-eu-label">Drohnenklasse</div><div class="dc-eu-val"><span class="bdg-eu ${euBadgeClass(d.eu)}">${esc(d.eu)}</span></div></div>
      <div class="dc-eu-col"><div class="dc-eu-label">Flugkategorie</div><div class="dc-eu-val">${katChip(d.kat)}</div></div>
      <div class="dc-eu-col"><div class="dc-eu-label">Führerschein (EU)</div><div class="dc-eu-val">${fscheinChip(d.fs)}</div></div>
      <div class="dc-eu-note">${euNote(d)}</div>
    </div>
    <div class="dc-datengrid">
      <div class="dc-daten-cell price-cell"><div class="dc-daten-label">Preis (UVP)</div><div class="dc-daten-val ${isCl?'classified':''}">${preisStr}</div></div>
      <div class="dc-daten-cell"><div class="dc-daten-label">Bauform</div><div class="dc-daten-val">${esc(d.bf)}</div></div>
      <div class="dc-daten-cell"><div class="dc-daten-label">Baujahr</div><div class="dc-daten-val">${esc(d.bj)}</div></div>
      <div class="dc-daten-cell"><div class="dc-daten-label">Verwendungszweck</div><div class="dc-daten-val">${esc(d.zw)}</div></div>
      <div class="dc-daten-cell"><div class="dc-daten-label">Nutzlast</div><div class="dc-daten-val">${esc(d.nl)||'—'}</div></div>
      <div class="dc-daten-cell"><div class="dc-daten-label">Reichweite</div><div class="dc-daten-val">${esc(d.rw)}</div></div>
      <div class="dc-daten-cell"><div class="dc-daten-label">Kameraqualität</div><div class="dc-daten-val">${esc(d.kq)||'—'}</div></div>
      <div class="dc-daten-cell"><div class="dc-daten-label">Verbauter Sensor</div><div class="dc-daten-val">${esc(d.se)||'—'}</div></div>
      <div class="dc-daten-cell"><div class="dc-daten-label">Einsatzgebiet</div><div class="dc-daten-val">${esc(d.eg)}</div></div>
    </div>
    ${d.url&&d.url!=='#'?`<div class="dc-links"><a class="dc-link-btn dc-link-ext" href="${esc(d.url)}" target="_blank" rel="noopener">🔗 Offizielle Webseite ↗</a></div>`:''}
  </div></div>`;
}
function toggleCard(btn){const id=btn.dataset.id;const body=btn.closest('.dc').querySelector(`.dc-body[data-id="${id}"]`);if(!body)return;const isOpen=body.classList.toggle('open');btn.classList.toggle('open',isOpen);btn.setAttribute('aria-expanded',isOpen);btn.innerHTML=isOpen?'Weniger anzeigen <svg viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>':'Mehr Details <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>';}
updateStats();
</script>
</body>
</html>
