// ── STATE ──
let aktiveBauform=null;
const MAX_PREIS=15000;
function updateStats(){document.getElementById('statTotal').textContent=DROHNEN.length;document.getElementById('statH').textContent=new Set(DROHNEN.map(d=>d.h)).size;}
function updatePD(){const v=parseInt(document.getElementById('priceSlider').value);document.getElementById('priceDisplay').textContent=(v>=MAX_PREIS)?'Alle':'≤'+v.toLocaleString('de')+'€';}
const BAUFORM_DESC={
  'Multicopter':'Multi-Rotor-Drohnen — vom 135g Selfie-Nano bis zum 120kg Agrar-Oktokopter. Consumer, Profi, Enterprise, Agrar und Militär.',
  'VTOL':'VTOL-Systeme vereinen Multicopter-Flexibilität mit Starrflügler-Effizienz. Vermessungs-, Liefer- und Militär-UAS mit langen Flugzeiten.',
  'Fixed Wing':'Starrflügler-UAV — von handgestarteten ISR-Aufklärern bis zu bewaffneten MALE-UAS für Langzeit-ISR und Präzisionsschlag.'
};
const BAUFORM_FARBE={'Multicopter':'var(--mc)','VTOL':'var(--vt)','Fixed Wing':'var(--fw)'};
function loadBauform(bf){
  aktiveBauform=bf;
  document.getElementById('vHome').classList.add('hide');
  document.getElementById('vDetail').classList.remove('hide');
  document.getElementById('dTitle').textContent=bf;
  document.getElementById('dDesc').textContent=BAUFORM_DESC[bf]||'';
  document.getElementById('tbCr').innerHTML=`<b>${esc(bf)}</b>`;
  document.getElementById('dSrch').value='';
  document.getElementById('dSort').value='def';
  document.getElementById('priceSlider').value=MAX_PREIS;
  document.getElementById('euLegende').style.display='flex';
  updatePD();
  const liste=DROHNEN.filter(d=>d.bf===bf);
  document.getElementById('dStats').innerHTML=`<div class="ds"><div class="ds-n" style="color:${BAUFORM_FARBE[bf]}">${liste.length}</div><div class="ds-l">Modelle</div></div>`;
  renderDrohnen();
  window.scrollTo({top:0,behavior:'smooth'});
}
function goHome(){aktiveBauform=null;document.getElementById('vDetail').classList.add('hide');document.getElementById('vHome').classList.remove('hide');document.getElementById('tbCr').innerHTML='Übersicht';document.getElementById('euLegende').style.display='none';window.scrollTo({top:0,behavior:'smooth'});}
function filterAll(){renderDrohnen();}
function euSortVal(eu){const m={'C0':0,'C1':1,'C2':2,'C3':3,'Specific':4,'—':5,'Militär':6};return m[eu]??5;}
function renderDrohnen(){
  if(!aktiveBauform)return;
  const grid=document.getElementById('droneGrid');
  const query=(document.getElementById('dSrch').value||'').toLowerCase().trim();
  const sort=document.getElementById('dSort').value;
  const maxP=parseInt(document.getElementById('priceSlider').value);
  const openSet=new Set();
  grid.querySelectorAll('.dc-body.open').forEach(b=>openSet.add(b.dataset.id));
  let liste=DROHNEN.filter(d=>d.bf===aktiveBauform);
  if(query) liste=liste.filter(d=>(d.n+d.h+d.eg+d.zw+d.di+d.eu+d.kat).toLowerCase().includes(query));
  if(maxP<MAX_PREIS) liste=liste.filter(d=>d.preis===0||d.preis<=maxP);
  if(sort==='az') liste.sort((a,b)=>a.n.localeCompare(b.n,'de'));
  else if(sort==='preis_asc') liste.sort((a,b)=>(a.preis||99999)-(b.preis||99999));
  else if(sort==='preis_desc') liste.sort((a,b)=>(b.preis||0)-(a.preis||0));
  else if(sort==='eu') liste.sort((a,b)=>euSortVal(a.eu)-euSortVal(b.eu));
  else if(sort==='fd') liste.sort((a,b)=>parseFloat(b.fd)-parseFloat(a.fd));
  document.getElementById('dCnt').textContent=liste.length;
  document.getElementById('dCntLbl').textContent=liste.length===1?'Drohne':'Drohnen';
  if(liste.length===0){grid.innerHTML=`<div class="no-results"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>Keine Drohnen gefunden. <button onclick="document.getElementById('dSrch').value='';document.getElementById('priceSlider').value=${MAX_PREIS};updatePD();filterAll()" style="background:none;border:none;color:var(--ac);cursor:pointer;font-family:inherit;text-decoration:underline">Filter zurücksetzen</button></div>`;return;}
  grid.innerHTML=liste.map((d,i)=>buildCard(d,i)).join('');
  openSet.forEach(id=>{const body=grid.querySelector(`.dc-body[data-id="${id}"]`);const toggle=grid.querySelector(`.dc-toggle[data-id="${id}"]`);if(body)body.classList.add('open');if(toggle){toggle.classList.add('open');toggle.setAttribute('aria-expanded','true');toggle.innerHTML='Weniger anzeigen <svg viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>';}});
  // Bilder lazy-loaden
  grid.querySelectorAll('.dc-thumb[data-drone]').forEach(el=>observeThumb(el));
}
